# ════════════════════════════════════════════════════
#   AI Operations Center v3.0 — Environment Config
#   Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════

# ── Required: LLM API Keys ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here          # console.groq.com (free, no credit card)
GEMINI_API_KEY=AIza_your_gemini_api_key_here      # aistudio.google.com (free)

# ── Optional: Dashboard Security ─────────────────────────────────────────────
# If set, all API calls require header: X-API-Key: <this value>
# Leave blank for dev mode (no auth).
DASHBOARD_API_KEY=

# ════════════════════════════════════════════════════════════════════════════════
#   EMAIL INTEGRATION — Connect your real inbox (Gmail / Outlook / any IMAP)
#   The backend will auto-poll for new emails every 30 seconds and run the
#   full AI agent pipeline on each one automatically.
# ════════════════════════════════════════════════════════════════════════════════

# Gmail setup:
#   1. Google Account → Security → 2-Step Verification → App Passwords
#   2. Create App Password for "Mail" → copy the 16-char code below
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_USERNAME=you@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Outlook / Hotmail setup:
#   Enable IMAP in Outlook Settings → Sync email → IMAP
# EMAIL_IMAP_HOST=imap-mail.outlook.com
# EMAIL_USERNAME=you@outlook.com
# EMAIL_PASSWORD=your_outlook_password

# Yahoo Mail setup:
# EMAIL_IMAP_HOST=imap.mail.yahoo.com
# EMAIL_USERNAME=you@yahoo.com
# EMAIL_PASSWORD=your_app_password

# How often to check for new emails (seconds). Default: 30
EMAIL_POLL_INTERVAL=30

# ── Jira Integration ──────────────────────────────────────────────────────────
# Creates real tickets when an incident is processed.
# Jira API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your_email@domain.com
JIRA_API_TOKEN=your_jira_api_token

# ── Slack Integration ─────────────────────────────────────────────────────────
# Sends approval requests + notifications to Slack.
# Bot token: https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C1234567890

# ── Google Calendar Integration ───────────────────────────────────────────────
# Schedules meetings automatically for P1 incidents.
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials.json

# ── Datadog Monitoring ────────────────────────────────────────────────────────
# Fetches real system logs for incident analysis.
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key

# ── Qdrant (Persistent mode — optional) ──────────────────────────────────────
# By default, Qdrant runs in-memory (resets on restart).
# To persist the knowledge base across restarts, run:
#   docker run -p 6333:6333 qdrant/qdrant
# Then uncomment:
# QDRANT_URL=http://localhost:6333

# ── Observability — LangFuse (Optional) ──────────────────────────────────────
# Full agent tracing dashboard. Sign up at cloud.langfuse.com (free tier).
# Also uncomment langfuse in requirements.txt
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
